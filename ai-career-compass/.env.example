# ============================================
# GEMINI API KEYS (Multiple for Load Balancing)
# ============================================
# Get your keys from: https://makersuite.google.com/app/apikey
# You can use the same key for all, or different keys to distribute load

# Primary API Key - Used for Chatbot
VITE_GEMINI_API_KEY_CHATBOT=your_gemini_api_key_here

# API Key for Flashcard Generation
VITE_GEMINI_API_KEY_FLASHCARDS=your_gemini_api_key_here

# API Key for Quiz Generation
VITE_GEMINI_API_KEY_QUIZ=your_gemini_api_key_here

# API Key for Study Plans
VITE_GEMINI_API_KEY_STUDY_PLANS=your_gemini_api_key_here

# API Key for Career Analysis
VITE_GEMINI_API_KEY_CAREER_ANALYSIS=your_gemini_api_key_here

# API Key for Content Summarization
VITE_GEMINI_API_KEY_SUMMARIZATION=your_gemini_api_key_here

# API Key for Practice Problems
VITE_GEMINI_API_KEY_PRACTICE=your_gemini_api_key_here

# API Key for Progress Analysis
VITE_GEMINI_API_KEY_ANALYTICS=your_gemini_api_key_here

# ============================================
# FIREBASE CONFIGURATION
# ============================================
# Get these from Firebase Console > Project Settings > General
VITE_FIREBASE_API_KEY=your_firebase_api_key
VITE_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your_project_id
VITE_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ============================================
# SUPABASE CONFIGURATION
# ============================================
# Get these from Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL=https://your_project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# ============================================
# LEGACY SETTINGS (Optional - for Django backend)
# ============================================
VITE_API_URL=http://localhost:8000/api
VITE_USE_BACKEND=false
VITE_USE_LLM=false

# ============================================
# ANTHROPIC CLAUDE API KEY
# ============================================
# Get your key from: https://console.anthropic.com/
VITE_ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ============================================
# OPENAI API KEY
# ============================================
# Get your key from: https://platform.openai.com/api-keys
VITE_OPENAI_API_KEY=your_openai_api_key_here
